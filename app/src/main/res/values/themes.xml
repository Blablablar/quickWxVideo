<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.NfcDemo" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
    </style>

    <style name="Theme.NfcDemo.Write" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <item name="colorPrimary">#07C160</item>
        <item name="colorOnPrimary">@android:color/white</item>
        <item name="colorPrimaryVariant">#06AD56</item>
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:statusBarColor" tools:targetApi="l">@android:color/white</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">true</item>
        <item name="actionBarStyle">@style/Widget.NfcDemo.ActionBar</item>
        <item name="actionBarTheme">@style/ThemeOverlay.NfcDemo.ActionBar</item>
    </style>

    <style name="Widget.NfcDemo.ActionBar" parent="Widget.MaterialComponents.ActionBar.Solid">
        <item name="background">@android:color/white</item>
        <item name="elevation">0dp</item>
        <item name="titleTextStyle">@style/TextAppearance.NfcDemo.ActionBar.Title</item>
    </style>

    <style name="TextAppearance.NfcDemo.ActionBar.Title" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@android:color/black</item>
    </style>

    <style name="ThemeOverlay.NfcDemo.ActionBar" parent="ThemeOverlay.MaterialComponents.ActionBar">
        <item name="colorControlNormal">@android:color/black</item>
    </style>
</resources>
