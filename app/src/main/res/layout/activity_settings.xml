<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/pref_action_after_read"
            android:textSize="16sp"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/rg_action_after_read"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp">

            <RadioButton
                android:id="@+id/rb_wechat_video"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pref_action_wechat_video"
                android:padding="8dp" />

            <RadioButton
                android:id="@+id/rb_dial_number"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pref_action_dial_number"
                android:padding="8dp" />

            <RadioButton
                android:id="@+id/rb_no_action"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/pref_action_no_action"
                android:padding="8dp" />

        </RadioGroup>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="#999999"
            android:textSize="13sp"
            android:text="@string/pref_action_after_read_desc" />

    </LinearLayout>
</ScrollView>
